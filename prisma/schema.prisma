generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Event {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  date        DateTime
  startDate   DateTime?
  endDate     DateTime?
  location    String
  category    String?
  image       String?
  sessions    Session[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Session {
  id          Int        @id @default(autoincrement())
  title       String
  description String?
  date        DateTime?
  time        String
  startTime   String?
  endTime     String?
  duration    Float      @default(1)
  roomId      String?
  room        String
  capacity    Int?
  eventId     Int
  event       Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  speakers    Speaker[]
  questions   Question[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Speaker {
  id        String    @id
  name      String
  role      String?
  bio       String?
  avatar    String?
  image     String?
  expertise String[]  @default([])
  links     Json?
  sessions  Session[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Question {
  id        Int      @id @default(autoincrement())
  sessionId Int
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  content   String
  author    String?
  upvotes   Int      @default(0)
  createdAt DateTime @default(now())
}
